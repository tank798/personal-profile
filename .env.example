PORT=8080
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/homepage_platform
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN_SECONDS=86400
CORS_ORIGINS=*

# Single-owner mode
ADMIN_EMAIL=you@example.com
ADMIN_USERNAME=yourname
ADMIN_DISPLAY_NAME=你的名字
ADMIN_PASSWORD=change-this-password
ADMIN_BIO=热爱生活与创造
SITE_SLUG=yourname
SITE_TITLE=你的主页
SITE_SUBTITLE=记录生活与想法
SITE_ABOUT_MD=
SYNC_ADMIN_PASSWORD_ON_BOOT=false

# Object storage
OBJECT_STORAGE_UPLOAD_BASE_URL=https://upload.example.com
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
UPLOAD_URL_TTL_SECONDS=600
